    <script>
    (function () {
        const hamburger = document.getElementById('hamburger');
        const navLinks  = document.getElementById('nav-links');
        const overlay   = document.getElementById('nav-overlay');

        const subpanel = document.createElement('div');
        subpanel.className = 'mobile-subpanel';
        subpanel.id = 'mobile-subpanel';
        subpanel.setAttribute('aria-hidden', 'true');
        document.body.appendChild(subpanel);

        function isMobile() { return window.innerWidth <= 768; }

        function openMenu() {
            navLinks.classList.add('is-open');
            hamburger.setAttribute('aria-expanded', 'true');
            hamburger.setAttribute('aria-label', 'Close menu');
            document.body.classList.add('menu-open');
        }

        function closeMenu() {
            closeSubpanel(false);          
            navLinks.classList.remove('is-open');
            hamburger.setAttribute('aria-expanded', 'false');
            hamburger.setAttribute('aria-label', 'Open menu');
            document.body.classList.remove('menu-open');
        }

        function openSubpanel(navItem) {
            const label   = navItem.querySelector('.nav-link').textContent.trim();
            const megaMenu = navItem.querySelector('.mega-menu');
            if (!megaMenu) return;

            let html = '';

            html += '<div class="subpanel-controls">';
            html += '<button class="subpanel-back" aria-label="Back to menu">Back</button>';
            html += '<button class="subpanel-close" aria-label="Close menu"></button>';
            html += '</div>';

            html += '<ul class="subpanel-list">';

            megaMenu.querySelectorAll('.mega-col').forEach(function (col) {
                const colLabel = col.querySelector('.mega-label');
                const links = col.querySelectorAll('a.mega-link');
                if (!links.length) return;

                if (colLabel) {
                    html += '<li class="subpanel-label">' + colLabel.textContent.trim() + '</li>';
                }

                links.forEach(function (a) {
                    const isLarge = a.classList.contains('mega-link--large');
                    const isSecondary = a.classList.contains('mega-link--secondary');
                    const smallClass = (!isLarge || isSecondary) ? ' subpanel-link--small' : '';

                    html += '<li class="subpanel-item">';
                    html += '<a href="' + a.getAttribute('href') + '" class="subpanel-link' + smallClass + '">';
                    html += a.textContent.trim();
                    html += '</a></li>';
                });
            });

            html += '</ul>';

            subpanel.innerHTML = html;
            subpanel.setAttribute('aria-hidden', 'false');
            subpanel.classList.add('is-visible');

            subpanel.querySelector('.subpanel-back').addEventListener('click', function () {
                closeSubpanel(true);
            });

            subpanel.querySelector('.subpanel-close').addEventListener('click', function () {
                closeMenu();
            });

            subpanel.querySelectorAll('.subpanel-link').forEach(function (link) {
                link.addEventListener('click', function () {
                    closeMenu();
                });
            });
        }

        function closeSubpanel(keepMenuOpen) {
            subpanel.classList.remove('is-visible');
            subpanel.setAttribute('aria-hidden', 'true');
            setTimeout(function () {
                if (!subpanel.classList.contains('is-visible')) {
                    subpanel.innerHTML = '';
                }
            }, 300);
        }

        hamburger.addEventListener('click', function () {
            if (navLinks.classList.contains('is-open')) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        navLinks.querySelectorAll('.nav-item.has-dropdown').forEach(function (item) {
            item.querySelector('.nav-link').addEventListener('click', function (e) {
                if (isMobile()) {
                    e.preventDefault();     
                    openSubpanel(item);
                }
            });
        });

        overlay.addEventListener('click', closeMenu);

        window.addEventListener('resize', function () {
            if (!isMobile()) closeMenu();
        });
    }());
    </script>

