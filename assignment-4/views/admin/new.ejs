<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Add Product</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

    <aside class="admin-sidebar">
        <div class="admin-brand">
            <svg height="36" viewBox="0 0 14 44" width="14" xmlns="http://www.w3.org/2000/svg">
                <path d="m13.0729 17.6825a3.61 3.61 0 0 0 -1.7502 3.0365 3.5132 3.5132 0 0 0 2.1404 3.2154 8.394 8.394 0 0 1 -1.0948 2.2071c-.6392.9538-1.3139 1.9081-2.3726 1.9081s-1.3044-.6106-2.4923-.6106c-1.1585 0-1.5733.6327-2.5581.6327s-1.6476-.8852-2.3977-1.9648a9.7968 9.7968 0 0 1 -1.5927-5.2069 4.2569 4.2569 0 0 1 3.9855-4.5745 3.517 3.517 0 0 1 2.5315 1.0295c.3867.3538.8867.5381 1.4035.5176a2.7659 2.7659 0 0 0 1.6823-.6327 3.5672 3.5672 0 0 1 2.4285-.868zm-3.1441-2.7127a3.462 3.462 0 0 0 .8053-2.3843 3.58 3.58 0 0 0 -2.3339 1.2108 3.3573 3.3573 0 0 0 -.8468 2.3252 2.9653 2.9653 0 0 0 2.3754-1.1517z" fill="#fff"/>
            </svg>
            <span class="admin-brand-text">Admin</span>
        </div>
        <nav class="admin-nav">
            <a href="/admin" class="admin-nav-link">Dashboard</a>
            <a href="/admin/new" class="admin-nav-link admin-nav-active">Add Product</a>
            <a href="/products" class="admin-nav-link">View Store</a>
            <a href="/" class="admin-nav-link">Back to Site</a>
        </nav>
    </aside>

    <main class="admin-main">
        <header class="admin-header">
            <h1 class="admin-title">Add Product</h1>
            <a href="/admin" class="admin-btn">Cancel</a>
        </header>

        <% if (error) { %>
            <div class="admin-error"><%= error %></div>
        <% } %>

        <form action="/admin/new" method="POST" enctype="multipart/form-data" class="admin-form">

            <div class="form-row">
                <label class="form-label">Name</label>
                <input type="text" name="name" value="<%= values.name || '' %>" required class="form-input">
            </div>

            <div class="form-row">
                <label class="form-label">Category</label>
                <input type="text" name="category" value="<%= values.category || '' %>" required class="form-input" placeholder="iPhone, Mac, iPad, Watch, AirPods, TV & Home, Accessories">
            </div>

            <div class="form-grid">
                <div class="form-row">
                    <label class="form-label">Price ($)</label>
                    <input type="number" name="price" value="<%= values.price || '' %>" required min="0" step="0.01" class="form-input">
                </div>
                <div class="form-row">
                    <label class="form-label">Stock</label>
                    <input type="number" name="stock" value="<%= values.stock || 0 %>" min="0" class="form-input">
                </div>
                <div class="form-row">
                    <label class="form-label">Rating (0 - 5)</label>
                    <input type="number" name="rating" value="<%= values.rating || 0 %>" min="0" max="5" step="0.1" class="form-input">
                </div>
            </div>

            <div class="form-row">
                <label class="form-label">Image</label>
                <input type="file" name="image" accept="image/*" class="form-input form-file">
            </div>

            <div class="form-actions">
                <button type="submit" class="admin-btn admin-btn-primary">Save Product</button>
                <a href="/admin" class="admin-btn">Cancel</a>
            </div>
        </form>
    </main>

</body>
</html>
